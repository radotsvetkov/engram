# Rust
/target
**/target
Cargo.lock.bak

# Node / desktop
node_modules/
dist/
.vite/
*.tsbuildinfo
# ...but the desktop shell's dist is a committed placeholder (the window loads the daemon's
# own dashboard, so this page is only a fallback) - keep it tracked.
!/desktop/dist/
!/desktop/dist/index.html
# Tauri build-generated schemas and capability manifests.
/desktop/src-tauri/gen/

# Engram runtime state (local brain - never commit personal memory)
/.engram/
*.engram
brain/**/*.db
brain/**/*.db-wal
brain/**/*.db-shm
*.sqlite
*.sqlite-*

# Secrets & env
.env
.env.*
!.env.example
secrets/
*.key
*.pem

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Logs & temp
*.log
tmp/
.cache/

# Tauri sidecar binaries (copied build artifacts)
/desktop/src-tauri/binaries/

# Local preview-server config (points at a session scratchpad path)
.claude/launch.json
